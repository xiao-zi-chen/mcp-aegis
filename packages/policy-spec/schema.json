{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpaegis.io/schema/policy-bundle-v1alpha1.json",
  "title": "MCP Aegis PolicyBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "mcpaegis.io/v1alpha1" },
    "kind": { "const": "PolicyBundle" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
        "version": { "type": "integer", "minimum": 1 },
        "description": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaults", "profiles", "rules"],
      "properties": {
        "defaults": { "$ref": "#/$defs/defaults" },
        "profiles": { "$ref": "#/$defs/profiles" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installDecision", "runtimeProfile", "remoteAccess"],
      "properties": {
        "installDecision": { "$ref": "#/$defs/decision" },
        "runtimeProfile": { "type": "string", "minLength": 1 },
        "remoteAccess": { "$ref": "#/$defs/decision" }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sandbox"],
      "properties": {
        "sandbox": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
          "additionalProperties": { "$ref": "#/$defs/sandboxProfile" }
        }
      }
    },
    "sandboxProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readOnlyRootFs", "networkMode", "resources"],
      "properties": {
        "readOnlyRootFs": { "type": "boolean" },
        "mounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/mount" }
        },
        "networkMode": {
          "enum": ["none", "egress-allowlist"]
        },
        "network": { "$ref": "#/$defs/networkPolicy" },
        "environment": { "$ref": "#/$defs/environmentPolicy" },
        "secrets": { "$ref": "#/$defs/secretsPolicy" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpuShares", "memoryMb", "processLimit", "timeoutSeconds"],
      "properties": {
        "cpuShares": { "type": "integer", "minimum": 2 },
        "memoryMb": { "type": "integer", "minimum": 64 },
        "processLimit": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "mount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostPath", "containerPath", "readOnly"],
      "properties": {
        "hostPath": { "type": "string", "minLength": 1 },
        "containerPath": { "type": "string", "minLength": 1 },
        "readOnly": { "type": "boolean" },
        "createIfMissing": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": {
          "type": "array",
          "items": { "$ref": "#/$defs/networkTarget" }
        }
      }
    },
    "networkTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "suffix": { "type": "string" },
        "ports": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "minItems": 1
        }
      },
      "anyOf": [
        { "required": ["host", "ports"] },
        { "required": ["suffix", "ports"] }
      ]
    },
    "environmentPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
        }
      }
    },
    "secretsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,62}$" }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "action"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
        "match": { "$ref": "#/$defs/match" },
        "action": { "$ref": "#/$defs/action" }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/sourceMatch" },
        "server": { "$ref": "#/$defs/serverMatch" },
        "transport": { "$ref": "#/$defs/listMatch" },
        "risk": { "$ref": "#/$defs/riskMatch" },
        "ownership": { "$ref": "#/$defs/ownershipMatch" },
        "remote": { "$ref": "#/$defs/remoteMatch" },
        "labels": { "$ref": "#/$defs/listMatch" }
      },
      "minProperties": 1
    },
    "sourceMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": { "type": "string" },
        "packageType": {
          "enum": ["pypi", "npm", "oci", "github-release", "mcpb", "unknown"]
        }
      }
    },
    "serverMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "publisher": { "type": "string" },
        "version": { "type": "string" },
        "digest": { "type": "string" }
      }
    },
    "listMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "in": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "required": ["in"]
    },
    "riskMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": { "$ref": "#/$defs/numberRange" },
        "class": { "$ref": "#/$defs/listMatch" }
      }
    },
    "numberRange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gte": { "type": "number" },
        "lte": { "type": "number" }
      },
      "minProperties": 1
    },
    "ownershipMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verified": { "type": "boolean" }
      }
    },
    "remoteMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installDecision": { "$ref": "#/$defs/decision" },
        "runtimeProfile": { "type": "string" },
        "requireDigestPin": { "type": "boolean" },
        "remoteAccess": { "$ref": "#/$defs/decision" },
        "reason": { "type": "string" }
      },
      "minProperties": 1
    },
    "decision": {
      "enum": ["allow", "review", "restricted", "deny"]
    }
  }
}
